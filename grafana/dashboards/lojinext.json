{
  "title": "LojiNext Live Metrics",
  "panels": [
    {
      "type": "timeseries",
      "title": "FastAPI Request Rate",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (method)",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "FastAPI Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    }
  ],
  "schemaVersion": 36
}
