# Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to source control!

# =============================================================================
# SECURITY - REQUIRED
# =============================================================================

# Default admin password (REQUIRED - no fallback)
# Generate strong password: openssl rand -base64 24
DEFAULT_ADMIN_PASSWORD=
ADMIN_PASSWORD=

# JWT Secret Key (REQUIRED)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Environment (dev/prod/test)
ENVIRONMENT=dev

# =============================================================================
# DATABASE - REQUIRED
# =============================================================================

# PostgreSQL: postgresql+asyncpg://user:pass@host:port/db
# SQLite: sqlite+aiosqlite:///./data/app.db
DATABASE_URL=

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# OpenRouteService API Key (mesafe hesaplama için)
# Get your key: https://openrouteservice.org/dev/#/signup
# Free tier: 40 requests/minute
OPENROUTESERVICE_API_KEY=

# =============================================================================
# APPLICATION SETTINGS (Optional)
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

