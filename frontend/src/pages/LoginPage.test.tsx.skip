import { render, screen, fireEvent, waitFor } from '@testing-library/react'
import { describe, it, expect, vi, beforeEach } from 'vitest'
import { BrowserRouter } from 'react-router-dom'
import LoginPage from '../pages/LoginPage'
import { AuthProvider } from '../context/AuthContext'
import * as api from '../services/api'

// Mock API
vi.mock('../services/api', async () => {
    const actual = await vi.importActual('../services/api')
    return {
        ...actual,
        authApi: {
            login: vi.fn(),
        },
        tokenStorage: {
            set: vi.fn(),
            get: vi.fn(),
            remove: vi.fn(),
        }
    }
})

// Wrapper for providers
const renderLogin = () => {
    return render(
        <AuthProvider>
            <BrowserRouter>
                <LoginPage />
            </BrowserRouter>
        </AuthProvider>
    )
}

describe('LoginPage', () => {
    beforeEach(() => {
        vi.clearAllMocks()
    })

    it('renders login form correctly', () => {
        renderLogin()

        expect(screen.getByText('LojiNext AI')).toBeInTheDocument()
        expect(screen.getByLabelText('Kullanıcı Adı')).toBeInTheDocument()
        expect(screen.getByLabelText('Şifre')).toBeInTheDocument()
        expect(screen.getByRole('button', { name: /giriş yap/i })).toBeInTheDocument()
    })

    it('shows error when submitting empty form', async () => {
        renderLogin()

        const submitBtn = screen.getByRole('button', { name: /giriş yap/i })
        fireEvent.click(submitBtn)

        expect(await screen.findByText('Lütfen tüm alanları doldurun')).toBeInTheDocument()
    })

    it('handles successful login', async () => {
        // Mock successful login response
        (api.authApi.login as any).mockResolvedValue({
            access_token: 'fake-token',
            token_type: 'bearer'
        })

        renderLogin()

        // Fill form
        fireEvent.change(screen.getByLabelText('Kullanıcı Adı'), { target: { value: 'testuser' } })
        fireEvent.change(screen.getByLabelText('Şifre'), { target: { value: 'password123' } })

        // Submit
        fireEvent.click(screen.getByRole('button', { name: /giriş yap/i }))

        // Loading state check
        expect(screen.getByText('Giriş yapılıyor...')).toBeInTheDocument()

        // Login function called?
        await waitFor(() => {
            expect(api.authApi.login).toHaveBeenCalledWith('testuser', 'password123')
            expect(api.tokenStorage.set).toHaveBeenCalledWith('fake-token')
        })
    })

    it('handles login error', async () => {
        // Mock error response
        (api.authApi.login as any).mockRejectedValue(new Error('Kullanıcı adı veya şifre hatalı'))

        renderLogin()

        fireEvent.change(screen.getByLabelText('Kullanıcı Adı'), { target: { value: 'wrong' } })
        fireEvent.change(screen.getByLabelText('Şifre'), { target: { value: 'wrong' } })
        fireEvent.click(screen.getByRole('button', { name: /giriş yap/i }))

        expect(await screen.findByText('Kullanıcı adı veya şifre hatalı')).toBeInTheDocument()
    })

    it('toggles password visibility', () => {
        renderLogin()

        const passwordInput = screen.getByLabelText('Şifre') as HTMLInputElement
        const toggleBtn = screen.getByLabelText('Şifreyi göster')

        expect(passwordInput.type).toBe('password')

        fireEvent.click(toggleBtn)
        expect(passwordInput.type).toBe('text')

        fireEvent.click(screen.getByLabelText('Şifreyi gizle'))
        expect(passwordInput.type).toBe('password')
    })
})
